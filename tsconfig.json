{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/*"],
      "@restaurant-qr/shared": ["packages/shared/src"],
      "@restaurant-qr/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": [
    "tests/**/*",
    "packages/shared/src/**/*"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
