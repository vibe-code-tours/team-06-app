# supabase/.env.test.example — commit THIS file, never your real .env.test.
#
#   1. `supabase/.env.test` is gitignored. Never commit real keys.
#   2. Copy it:  cp supabase/.env.test.example supabase/.env.test
#   3. Run `supabase start` — it prints these same values for your local instance.
#      Defaults below match the local CLI's standard ports/keys.
#   4. Tests in tests/db/** and tests/rls/** use these to connect via
#      tests/helpers/supabaseTestClient.ts — they run against a REAL local
#      Postgres/Auth instance, not a mock.
#   5. Never point this at a staging/production project — resetDatabase.ts
#      truncates tables between test runs.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key
